# Poll service
GRPC_ADDR=:50052

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/poll_service?sslmode=disable

# Auth service gRPC endpoint
AUTH_GRPC_ENDPOINT=auth-service:50051

# Outbox relay
OUTBOX_RELAY_INTERVAL=1s
OUTBOX_RELAY_BATCH_SIZE=100

# Event publisher: log | kafka
EVENT_PUBLISHER=log

# Kafka (required when EVENT_PUBLISHER=kafka)
# KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=
KAFKA_WRITE_TIMEOUT=5s
