GRPC_ADDR=:50056
HTTP_ADDR=:8081
AUTH_GRPC_ENDPOINT=auth-service:50051

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
MAX_CONNECTIONS_PER_IP=30
CONNECT_RATE_PER_MINUTE=120

KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_PREFIX=
KAFKA_READ_TIMEOUT=10s
KAFKA_COMMIT_PERIOD=1s
KAFKA_GROUP_ID=realtime-service

STREAM_BUFFER=256
EVENT_DEDUP_TTL=2m
SSE_HEARTBEAT_INTERVAL=20s
WS_PING_INTERVAL=25s
WS_WRITE_TIMEOUT=5s
